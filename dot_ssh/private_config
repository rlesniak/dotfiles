# SSH config managed by chezmoi.
# SSH keys are served by Bitwarden SSH Agent.
# IdentityFile points to .pub files so SSH knows which key to request from the agent.
# Note: OrbStack adds its own Include block automatically after installation.
# VPS-specific hosts (IPs) are not tracked here — add them manually per machine.

# Personal GitHub Account
Host private
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_private.pub
    IdentitiesOnly yes

# Company GitHub Account
Host akiro
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_akiro.pub
    IdentitiesOnly yes

# GitHub via port 443 (if port 22 is blocked)
Host github.com
    HostName ssh.github.com
    Port 443
    User git
    IdentityFile ~/.ssh/id_private.pub
    IdentitiesOnly yes
