# SSH config managed by chezmoi.
# SSH keys are served by Bitwarden SSH Agent — no IdentityFile needed.
# Note: OrbStack adds its own Include block automatically after installation.
# VPS-specific hosts (IPs) are not tracked here — add them manually per machine.

# Personal GitHub Account
Host private
    HostName github.com
    User git

# Company GitHub Account
Host akiro
    HostName github.com
    User git

# GitHub via port 443 (if port 22 is blocked)
Host github.com
    HostName ssh.github.com
    Port 443
    User git
